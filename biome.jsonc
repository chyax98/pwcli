{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "includes": [
      "**",
      "!!**/dist",
      "!!**/node_modules",
      "!!**/.playwright-cli",
      "!!**/.pwcli",
      "!!**/scripts/manual/bootstrap-verify.js",
      "!!**/scripts/manual/diagnostics-fixture.js",
      "!!**/scripts/e2e/dogfood-bootstrap.js"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true
  }
}
