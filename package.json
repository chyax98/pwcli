{
  "name": "@chyax/pwcli",
  "version": "0.2.0",
  "private": false,
  "description": "Agent-first Playwright CLI — browser facts, actions, diagnostics and recovery for AI agents",
  "type": "module",
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "bin": {
    "pw": "dist/cli.js"
  },
  "engines": {
    "node": ">=24.12.0 <26"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test:regression": "pnpm build && bash scripts/smoke/pwcli-smoke.sh",
    "smoke": "pnpm run test:regression",
    "test:dogfood": "pnpm run test:regression",
    "test:dogfood:e2e": "pnpm build && bash scripts/e2e/pwcli-dogfood-e2e.sh",
    "check:skill": "node scripts/check-skill-contract.js"
  },
  "imports": {
    "#engine/*": "./dist/engine/*",
    "#cli/*":    "./dist/cli/*",
    "#store/*":  "./dist/store/*",
    "#auth/*":   "./dist/auth/*"
  },
  "dependencies": {
    "citty": "0.1.6",
    "commander": "14.0.3",
    "playwright-core": "1.59.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "25.6.0",
    "tsx": "4.20.6",
    "typescript": "6.0.3"
  }
}
