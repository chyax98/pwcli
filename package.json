{
  "name": "@chyax/pwcli",
  "version": "1.0.0",
  "private": false,
  "description": "Agent-first Playwright CLI — browser facts, actions, diagnostics and recovery for AI agents",
  "type": "module",
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "bin": {
    "pw": "dist/cli.js"
  },
  "engines": {
    "node": ">=24.12.0 <26"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check --diagnostic-level=error .",
    "lint:fix": "biome check --write .",
    "test": "tsx --test test/unit/*.test.ts test/integration/command-help.test.ts test/integration/batch-allowlist.test.ts test/integration/fixture-app.test.ts test/integration/diagnostics-failure-run.test.ts test/integration/profile-capability-probe.test.ts",
    "test:unit": "tsx --test test/unit/*.test.ts",
    "test:integration": "tsx --test test/integration/*.test.ts",
    "smoke": "pnpm build && bash test/smoke/pwcli-smoke.sh",
    "test:dogfood:e2e": "pnpm build && bash test/e2e/pwcli-dogfood-e2e.sh",
    "check": "pnpm typecheck && pnpm lint && pnpm build && pnpm test && pnpm check:help && pnpm check:skill && pnpm check:skill-install",
    "pack:check": "npm pack --dry-run",
    "check:skill": "node test/contract/check-skill-contract.js",
    "check:env-geolocation": "node test/contract/check-environment-geolocation-contract.js",
    "check:batch-verify": "node test/contract/check-batch-verify-contract.js",
    "check:trace-inspect": "node test/contract/check-trace-inspect-contract.js",
    "check:doctor-modal": "node test/contract/check-doctor-modal-contract.js",
    "check:run-code-timeout": "node test/contract/check-run-code-timeout-recovery.js",
    "check:har-1-0": "node test/contract/check-har-1-0-decision.js",
    "check:help": "node test/contract/check-help-contract.js",
    "check:skill-install": "node test/contract/check-skill-install-contract.js"
  },
  "imports": {
    "#engine/*": "./dist/engine/*",
    "#cli/*": "./dist/cli/*",
    "#store/*": "./dist/store/*",
    "#auth/*": "./dist/auth/*"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "playwright-core": "1.59.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "25.6.0",
    "tsx": "4.20.6",
    "typescript": "6.0.3"
  }
}
