{
  "name": "@chyax/pwcli",
  "version": "1.0.0",
  "private": false,
  "description": "Agent-first Playwright CLI — browser facts, actions, diagnostics and recovery for AI agents",
  "type": "module",
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "bin": {
    "pw": "dist/cli.js"
  },
  "engines": {
    "node": ">=24.12.0 <26"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "prepare": "husky",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check --diagnostic-level=error .",
    "lint:fix": "biome check --write .",
    "test": "pnpm test:unit && pnpm test:integration:core",
    "test:unit": "tsx --test test/unit/*.test.ts",
    "test:integration:core": "pnpm build && node test/integration/run-core.js",
    "test:integration": "pnpm build && tsx --test test/integration/*.test.ts",
    "test:contract": "pnpm build && node test/contract/run-all.js core",
    "test:contract:all": "pnpm build && node test/contract/run-all.js all",
    "test:smoke": "bash test/smoke/pwcli-smoke.sh",
    "test:e2e": "pnpm build && bash test/e2e/pwcli-dogfood-e2e.sh",
    "test:e2e:agent": "pnpm build && bash test/e2e/pwcli-agent-task-eval.sh",
    "smoke": "pnpm build && pnpm test:smoke",
    "check": "pnpm typecheck && pnpm lint && pnpm build && pnpm test:unit && node test/integration/run-core.js && node test/contract/run-all.js core",
    "pack:check": "npm pack --dry-run"
  },
  "imports": {
    "#engine/*": "./dist/engine/*",
    "#cli/*": "./dist/cli/*",
    "#store/*": "./dist/store/*",
    "#auth/*": "./dist/auth/*"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "playwright-core": "1.59.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "tsx": "4.20.6",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,json,md}": "biome check --diagnostic-level=error"
  }
}
