{
  "name": "pwcli",
  "version": "0.0.0-dev",
  "private": true,
  "description": "Agent-first Playwright orchestration CLI for internal use",
  "type": "module",
  "files": [
    "dist",
    "plugins",
    "skills",
    "README.md"
  ],
  "bin": {
    "pw": "dist/cli.js"
  },
  "engines": {
    "node": ">=24.12.0 <26"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "smoke": "pnpm build && bash scripts/smoke/pwcli-smoke.sh",
    "test:dogfood": "pnpm run smoke",
    "test:dogfood:e2e": "pnpm build && bash scripts/e2e/pwcli-dogfood-e2e.sh"
  },
  "dependencies": {
    "commander": "14.0.3",
    "playwright-core": "1.59.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "25.6.0",
    "tsx": "4.20.6",
    "typescript": "6.0.3"
  }
}
