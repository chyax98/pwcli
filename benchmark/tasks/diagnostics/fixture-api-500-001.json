{
  "id": "fixture-api-500-001",
  "title": "Classify a deterministic API 500 failure and preserve evidence",
  "category": "diagnostics",
  "mode": "fixture",
  "site": {
    "name": "deterministic-fixture",
    "startUrl": "http://127.0.0.1:<port>/api-500",
    "requiresLogin": false,
    "authMode": "none"
  },
  "goal": "Trigger a stable failing request, classify it as API_5XX, and collect the minimum recovery evidence bundle.",
  "allowedCommands": [
    "session",
    "open",
    "observe",
    "read-text",
    "network",
    "console",
    "errors",
    "diagnostics",
    "screenshot",
    "verify"
  ],
  "successCriteria": [
    {
      "id": "api-500-observed",
      "type": "network",
      "check": "At least one fixture request completes with HTTP status 500"
    },
    {
      "id": "failure-classified",
      "type": "custom",
      "check": "Task failure maps to API_5XX instead of a generic network failure"
    },
    {
      "id": "evidence-complete",
      "type": "artifact",
      "check": "Minimum evidence set is present and readable"
    }
  ],
  "failureTaxonomy": ["API_5XX", "NETWORK_FAILED", "VERIFY_FAILED", "ARTIFACT_INVALID"],
  "evidenceRequired": [
    "observe status",
    "network summary",
    "console output",
    "errors output",
    "diagnostics digest",
    "screenshot"
  ],
  "scoring": {
    "completion": 35,
    "evidence": 30,
    "diagnosis": 25,
    "efficiency": 10
  },
  "ciPolicy": {
    "allowedInCI": true,
    "allowedInNightly": true,
    "requiresManualReview": false
  }
}
