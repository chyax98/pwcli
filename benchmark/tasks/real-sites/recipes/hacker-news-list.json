{
  "kind": "list",
  "itemSelector": "tr.athing",
  "companionSelector": "tr",
  "fields": {
    "title": ".titleline > a, span.titleline > a",
    "url": {
      "selector": ".titleline > a, span.titleline > a",
      "attr": "href"
    },
    "site": ".sitestr",
    "points": {
      "selector": ".score",
      "source": "companion"
    },
    "author": {
      "selector": ".hnuser",
      "source": "companion"
    },
    "age": {
      "selector": ".age a",
      "source": "companion"
    },
    "comments": {
      "selector": ".subline > a:last-of-type",
      "source": "companion"
    }
  }
}
